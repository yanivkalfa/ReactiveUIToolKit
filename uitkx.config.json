{
  "formatter": {
    "printWidth": 100,
    "indentSize": 4,
    "indentStyle": "space",
    "singleAttributePerLine": false,
    "bracketSameLine": false,
    "closingBracketSameLine": true,
    "insertSpaceBeforeSelfClose": true,
    "preserveBlankLines": true,
    "maxConsecutiveBlankLines": 1,
    "trailingComma": false
  }
}
