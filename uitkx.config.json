{
  "formatter": {
    "printWidth": 80,
    "indentSize": 2,
    "indentStyle": "space",
    "singleAttributePerLine": false,
    "bracketSameLine": false,
    "closingBracketSameLine": false,
    "insertSpaceBeforeSelfClose": true,
    "insertMissingSemicolonsOnFormat": true,
    "preserveBlankLines": true,
    "maxConsecutiveBlankLines": 1,
    "trailingComma": false
  }
}
