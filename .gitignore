dist~/*

/Diagnostics/Benchmark/Results/*
/Diagnostics/Logs/Results/*

/.vscode/*

ReactiveUIToolKitDocs~/**/*.meta
ReactiveUIToolKitDocs~/dist/*
ReactiveUIToolKitDocs~/node_modules/*

# Source generator build artifacts — the compiled DLL in Analyzers/ IS committed;
# only the intermediate build output dirs and side-files are ignored.
SourceGenerator~/obj/
SourceGenerator~/bin/
SourceGenerator~/Tests/obj/
SourceGenerator~/Tests/bin/
Analyzers/*.deps.json
Analyzers/*.pdb

# VS extension build artifacts
ide-extensions~/visual-studio/UitkxVsix/bin/
ide-extensions~/visual-studio/UitkxVsix/obj/
ide-extensions~/visual-studio/UitkxVsix/server/
ide-extensions~/visual-studio/UitkxVsix/.vsix/

# LSP server build artifacts (bin/obj — the committed DLLs live directly in lsp-server/bin/Release/net8.0/)
ide-extensions~/lsp-server/obj/

# Publisher credentials — never commit the real token
publisher-secrets.json

