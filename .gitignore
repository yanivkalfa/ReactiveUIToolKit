dist~/*

/Diagnostics/Benchmark/Results/*
/Diagnostics/Logs/Results/*

/.vscode/*

ReactiveUIToolKitDocs~/**/*.meta
ReactiveUIToolKitDocs~/dist/*
ReactiveUIToolKitDocs~/node_modules/*

# ── Source generator ────────────────────────────────────────────
# The compiled DLL in Analyzers/ IS committed;
# only the intermediate build output dirs and side-files are ignored.
SourceGenerator~/obj/
SourceGenerator~/bin/
SourceGenerator~/Tests/obj/
SourceGenerator~/Tests/bin/

# ── Analyzers (distributed DLLs) ───────────────────────────────
# PDBs, deps.json, and their Unity .meta companions are not needed
Analyzers/*.deps.json
Analyzers/*.deps.json.meta
Analyzers/*.pdb
Analyzers/*.pdb.meta
Analyzers/publish/
Analyzers/publish.meta

# ── VSIX build artifacts (all IDEs) ────────────────────────────
# Never commit .vsix files anywhere in the repo
**/*.vsix
UitkxVsix.vsix.meta

# ── Visual Studio IDE cache ────────────────────────────────────
.vs/
ide-extensions~/visual-studio/UitkxVsix/.vs/

# VS2022 extension build artifacts
ide-extensions~/visual-studio/UitkxVsix/bin/
ide-extensions~/visual-studio/UitkxVsix/obj/
ide-extensions~/visual-studio/UitkxVsix/server/
ide-extensions~/visual-studio/UitkxVsix/_inspect_*/

# VS Code extension build artifacts
ide-extensions~/vscode/server/
ide-extensions~/vscode/node_modules/
ide-extensions~/vscode/CHANGELOG.md

# VS2022 marketplace overview (generated from centralized changelog)
ide-extensions~/visual-studio/UitkxVsix/overview.md
ide-extensions~/visual-studio/CHANGELOG.md

# LSP server build artifacts
ide-extensions~/lsp-server/bin/
ide-extensions~/lsp-server/obj/

# Language lib build artifacts
ide-extensions~/language-lib/bin/
ide-extensions~/language-lib/obj/

# ── Temporary debugging scripts ────────────────────────────────
*.csx
!SourceGenerator~/Tests/FormatTest.csx

# ── Credentials — never commit real tokens ─────────────────────
publisher-secrets.json
publisher-secrets.json.meta

# ── Stale/orphan entries ───────────────────────────────────────
_docs_branch/
_docs_branch.meta

DiabloMenuDemo/
DiabloMenuDemo.meta
DiabloMenuDemoFunc/
DiabloMenuDemoFunc.meta