@namespace PrettyUi.App.Components
@using UnityEngine.UIElements

export component PageShell(
  VirtualNode? sidebar = null,
  VirtualNode? content = null
) {
  return (
    <VisualElement style={Root}>
      {sidebar}
      <VisualElement style={Content}>
        {content}
      </VisualElement>
    </VisualElement>
  );
}
