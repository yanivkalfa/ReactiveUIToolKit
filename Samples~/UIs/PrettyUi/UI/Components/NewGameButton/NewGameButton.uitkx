import { AppButton } from "../AppButton/AppButton"
@namespace PrettyUi.App.Components
@using ReactiveUITK.Router
@using UnityEngine.UIElements

export component NewGameButton {
  var navigate = RouterHooks.UseNavigate();

  return (
    <VisualElement style={Wrapper}>
      <AppButton
        text="New Game"
        active={true}
        onClick={() => navigate("/game", null)}
        style={Button}
      />
    </VisualElement>
  );
}
