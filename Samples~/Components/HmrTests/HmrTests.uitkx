import * as Halibanius from "./SomeOtherName.style"

export VirtualNode HmrTests() {
  var (count, setCount) = useState(0);

  return (
    <VisualElement style={Halibanius.container}>
      <Text text={$"Count: {count}"} />
      <Button text="+" onClick={_ => setCount(count + 1)} />
    </VisualElement>
  );
}
