import { AppButton } from "../AppButton/AppButton"
import { ButtonStyle, Wrapper } from "./NewGameButton.style"
import "@UnityEngine.UIElements"

export VirtualNode NewGameButton() {
  var navigate = RouterHooks.UseNavigate();

  return (
    <VisualElement style={Wrapper}>
      <AppButton
        text="New Game"
        active={true}
        onClick={() => navigate("/game", null)}
        style={ButtonStyle}
      />
    </VisualElement>
  );
}
