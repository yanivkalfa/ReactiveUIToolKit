import { AppButton } from "../AppButton/AppButton"
import { Item, Wrapper } from "./Sidebar.style"
import "@UnityEngine.UIElements"

export VirtualNode Sidebar(IReadOnlyList<SidebarItem>? items = null) {
  var resolvedItems = items ?? Array.Empty<SidebarItem>();

  return (
    <VisualElement style={Wrapper}>
      @foreach (var item in resolvedItems) {
        return (
          <AppButton
            key={$"sidebar-{item.Id}"}
            text={item.Label}
            active={item.IsActive}
            disabled={item.Disabled}
            onClick={item.OnClick}
            style={Item}
          />
        );
      }
    </VisualElement>
  );
}
