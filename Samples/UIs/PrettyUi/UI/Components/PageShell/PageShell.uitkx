import { Content, Root } from "./PageShell.style"
import "@UnityEngine.UIElements"

export VirtualNode PageShell(VirtualNode? sidebar = null, VirtualNode? content = null) {
  return (
    <VisualElement style={Root}>
      {sidebar}
      <VisualElement style={Content}>
        {content}
      </VisualElement>
    </VisualElement>
  );
}
