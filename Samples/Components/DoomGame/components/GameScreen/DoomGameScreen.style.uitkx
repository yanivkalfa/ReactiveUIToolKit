    // Enemy sprite placeholder (colored rectangle)
    public static readonly Style EnemySprite = new Style {
      (StyleKeys.Position, "absolute"),
      (StyleKeys.BackgroundColor, new Color(0.8f, 0.2f, 0.1f, 1f)),
