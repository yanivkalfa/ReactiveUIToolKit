    // Minimap styles
    public static readonly Style MinimapContainer = new Style {
      (StyleKeys.Position, "absolute"),
      (StyleKeys.Right, 8f),
      (StyleKeys.Top, 8f),
      (StyleKeys.Width, 96f),
      (StyleKeys.Height, 96f),
      (StyleKeys.BackgroundColor, new Color(0f, 0f, 0f, 0.6f)),
      (StyleKeys.BorderWidth, 1f),
      (StyleKeys.BorderColor, new Color(0.4f, 0.4f, 0.4f, 0.5f)),
