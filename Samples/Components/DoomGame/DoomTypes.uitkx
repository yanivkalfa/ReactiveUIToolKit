@namespace Samples.DoomGame
@using System
@using System.Collections.Generic
@using UnityEngine

module DoomTypes {
  public enum GameScreen { MainMenu, Game }
  public enum Difficulty { Easy = 0, Normal = 1, Hard = 2 }

  public enum CellKind : byte {
    Empty = 0,
    Wall = 1,
    Door = 2,
    DoorBlue = 3,
    DoorYellow = 4,
    DoorRed = 5,
    Exit = 6,
    Liquid = 7,
  }

  public enum WeaponType : byte {
    Fist = 0, Pistol = 1, Shotgun = 2, Chaingun = 3,
    RocketLauncher = 4, PlasmaRifle = 5, BFG9000 = 6,
  }

  public enum AmmoType : byte {
    Bullets = 0, Shells = 1, Rockets = 2, Cells = 3, None = 255,
  }

  [Flags]
  public enum KeyCard : byte {
    None = 0, Blue = 1, Yellow = 2, Red = 4,
  }

  public enum MobjKind : byte {
    Player,
    Imp, Demon, Baron, Cacodemon, LostSoul, Zombieman, Shotgunner,
    ImpFireball, BaronBall, CacoBall, RocketProj, PlasmaProj, BfgProj,
    Explosion,
    PickupHealth, PickupArmor, PickupArmorBlue,
    PickupBullets, PickupShells, PickupRockets, PickupCells,
    PickupShotgun, PickupChaingun, PickupRocketLauncher, PickupPlasma, PickupBFG,
    KeyBlue, KeyYellow, KeyRed,
    Barrel, Light, Corpse,
  }

  public enum AIState : byte {
    Idle, Hunting, Attacking, Pain, Dying, Dead,
  }

  public struct Cell {
    public CellKind Kind;
    public byte WallTexIdx;
    public byte FloorTexIdx;
    public byte CeilingTexIdx;
    public byte LightLevel;
    public byte DoorState; // 0=closed, 255=open
    public byte DoorTimer;
    public byte Tag;
  }

  public struct MapDef {
    public int Width;
    public int Height;
    public Cell[] Cells;
    public string Name;

    public Cell AtSafe(int x, int y) {
      if (x < 0 || x >= Width || y < 0 || y >= Height) {
        return new Cell { Kind = CellKind.Wall, WallTexIdx = 0, LightLevel = 200 };
      }
      return Cells[y * Width + x];
    }

    public bool BlocksMovement(int x, int y) {
      var c = AtSafe(x, y);
      if (c.Kind == CellKind.Wall) return true;
      if (c.Kind == CellKind.Door || c.Kind == CellKind.DoorBlue || c.Kind == CellKind.DoorYellow || c.Kind == CellKind.DoorRed) {
        return c.DoorState < 200;
      }
      return false;
    }

    public bool BlocksRays(int x, int y) {
      var c = AtSafe(x, y);
      if (c.Kind == CellKind.Wall) return true;
      if (c.Kind == CellKind.Door || c.Kind == CellKind.DoorBlue || c.Kind == CellKind.DoorYellow || c.Kind == CellKind.DoorRed) {
        return c.DoorState < 250;
      }
      return false;
    }
  }

  public struct PlayerState {
    public float X, Y;
    public float Angle;
    public float Pitch; // pixels of Y-shear
    public int Health;
    public int Armor;
    public byte ArmorClass; // 0=none 1=green 2=blue
    public WeaponType Weapon;
    public int[] Ammo;
    public bool[] OwnedWeapons;
    public KeyCard Keys;
    public float ShootCooldown;
    public float MuzzleFlash;
    public float BobT;
    public bool Alive;
    public int FaceState; // 0=god,1..5=hp buckets,6=hurt,7=dead
    public float FaceTimer;
    public byte LastDamageDir; // 0=front 1=right 2=behind 3=left
    public float HurtFlash;
    public float PickupFlash;
    public float MessageTimer;
    public string MessageText;
  }

  public struct Mobj {
    public int Id;
    public MobjKind Kind;
    public AIState State;
    public float X, Y;
    public float MomX, MomY;
    public float Angle;
    public int Health;
    public float StateTimer;
    public float AttackCooldown;
    public int OwnerId;
    public int Damage;
    public float Radius;
    public bool Collected;
    public byte AnimFrame;
  }

  public struct WallSeg {
    public float TopPx;
    public float BotPx;
    public float Distance;
    public byte WallTexIdx;
    public float TexU;
    public byte LightLevel;
    public bool HitVertical;
    public bool IsSky;
  }

  public struct ColumnInfo {
    public WallSeg Main;
  }

  public struct FrameData {
    public ColumnInfo[] Columns;
    public float[] DepthBuffer;
  }

  public struct GameState {
    public PlayerState Player;
    public Mobj[] Mobjs;
    public int MobjCount;
    public int NextMobjId;
    public MapDef Map;
    public FrameData Frame;
    public int Level;
    public int Score;
    public int KillCount, KillTotal;
    public int Tic;
    public bool GameOver;
    public bool Victory;
    public Difficulty Difficulty;
    public int RngSeed;
    public float TimeAccum;
  }

  public struct InputCmd {
    public bool Forward, Back, StrafeLeft, StrafeRight;
    public bool TurnLeft, TurnRight;
    public bool Attack, Use, Run;
    public byte WeaponSwitch;
    public float YawDelta;
    public float PitchDelta;
  }

  public static class C {
