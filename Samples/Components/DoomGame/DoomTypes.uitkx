    public const float STRAFE_SPEED = 3.5f;
    public const float TURN_SPEED = 2.6f;
    public const float MAX_PITCH = 50f;
    public const float MOUSE_YAW_SENS = 0.008f;
    public const float MOUSE_PITCH_SENS = 0.15f;
    public const float PLAYER_RADIUS = 0.28f;

    public const float COOLDOWN_FIST = 0.35f;
    public const float COOLDOWN_PISTOL = 0.32f;
    public const float COOLDOWN_SHOTGUN = 0.85f;
    public const float COOLDOWN_CHAIN = 0.10f;
    public const float COOLDOWN_ROCKET = 1.0f;
    public const float COOLDOWN_PLASMA = 0.10f;
    public const float COOLDOWN_BFG = 1.5f;

    public const int DMG_FIST = 8;
    public const int DMG_PISTOL = 14;
    public const int DMG_PELLET = 9;
    public const int DMG_CHAIN = 11;
    public const int DMG_ROCKET = 100;
    public const int DMG_PLASMA = 18;
    public const int DMG_BFG = 350;
    public const int DMG_BARREL = 90;

    public const int MAX_BULLETS = 200;
    public const int MAX_SHELLS = 50;
    public const int MAX_ROCKETS = 50;
    public const int MAX_CELLS = 300;

    public const int START_HEALTH = 100;

    public const int HP_IMP = 60;
    public const int HP_DEMON = 150;
    public const int HP_BARON = 800;
    public const int HP_CACO = 400;
    public const int HP_LOST = 100;
    public const int HP_ZOMBIE = 20;
    public const int HP_SHOTG = 30;
    public const int HP_BARREL = 20;

    public const int DMG_IMP_MELEE = 12;
    public const int DMG_IMP_BALL = 18;
    public const int DMG_DEMON_BITE = 22;
    public const int DMG_BARON_CLAW = 30;
    public const int DMG_BARON_BALL = 60;
    public const int DMG_CACO_BALL = 28;
    public const int DMG_LOST_RAM = 14;
    public const int DMG_ZOMBIE = 9;
    public const int DMG_SHOTG = 12;

    public const float SPEED_IMP = 1.7f;
    public const float SPEED_DEMON = 2.6f;
    public const float SPEED_BARON = 1.5f;
    public const float SPEED_CACO = 1.4f;
    public const float SPEED_LOST = 3.5f;
    public const float SPEED_ZOMBIE = 1.4f;
    public const float SPEED_SHOTG = 1.5f;

    public const float SPEED_IMPBALL = 9f;
    public const float SPEED_BARONBALL = 11f;
    public const float SPEED_CACOBALL = 9f;
    public const float SPEED_ROCKET = 14f;
    public const float SPEED_PLASMA = 22f;
    public const float SPEED_BFG = 20f;

    public const int SCORE_IMP = 100;
    public const int SCORE_DEMON = 200;
    public const int SCORE_BARON = 1500;
    public const int SCORE_CACO = 600;
    public const int SCORE_LOST = 80;
    public const int SCORE_ZOMBIE = 60;
    public const int SCORE_SHOTG = 90;
    public const int SCORE_BARREL = 10;

    public const int MAX_MOBJS = 256;
    public const float SIGHT_RANGE = 18f;
