  MenuBuilderHandler buildMenu = dm =>
  {
    dm.AppendAction("Reset", _ => Reset());
    dm.AppendAction("Set 10", _ => setCount(10));
    dm.AppendAction("Set 100", _ => setCount(100));
    dm.AppendAction("Shuffle", _ => ShuffleOptions());
  };

  // ГўвЂќв‚¬ГўвЂќв‚¬ var: inline JSX node ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
  var inlineNode = (
    <Portal target={portalTarget}>
      @if (mounted) {
        return (
          <Button
            text="Portal Button (click me)"
            onClick={_ => AppendLog("Portal button clicked")}
            style={new Style { (StyleKeys.MarginTop, 6f) }}
          />
        );
      } @else {
        return (
          <Label text="Portal unmounted." />
        );
      }
    </Portal>
  );

  // ГўвЂќв‚¬ГўвЂќв‚¬ var: portalNode (setup-code JSX) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
  var portalNode = portalTarget != null
    ? (
      <Portal target={portalTarget}>
        @if (mounted) {
          return (
            <Button
              text="Portal Button (click me)"
              onClick={_ => AppendLog("Portal button clicked")}
              style={new Style { (StyleKeys.MarginTop, 6f) }}
            />
          );
        } @else {
          return (
            <Label text="Portal unmounted." />
          );
        }
      </Portal>
    )
    : null;

  // ГўвЂќв‚¬ГўвЂќв‚¬ bool helper ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
  bool IsLoading() => trigger > 1000;

  // ГўвЂќв‚¬ГўвЂќв‚¬ var: string.Join ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
  var optionsText = options.Count == 0
    ? "No options"
    : string.Join(", ", options);


  // в”Ђв”Ђ local function: JSX with @foreach + @if в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  var deepCategories = new[] { "A", "B", "C" };
  var deepPills = new[] { "x", "y", "z" };

  VirtualNode DeepPillBar(string[] opts, string selected) {
    return (
      <VisualElement
        style={new Style { (StyleKeys.FlexDirection, "row"), (StyleKeys.FlexWrap, "wrap"), (StyleKeys.MarginBottom, 6f) }}
      >
        @foreach (var opt in opts) {
          var isActive = opt == selected;
          var bg = isActive ? new Color(0.3f, 0.6f, 1f) : new Color(0.22f, 0.22f, 0.3f);

          return (
            <Button
              key={opt}
              text={opt.ToUpper()}
              onClick={_ => setMode(opt)}
              style={new Style {
                (StyleKeys.BackgroundColor, bg),
                (StyleKeys.Color, Color.white),
                (StyleKeys.BorderRadius, 10f),
                (StyleKeys.MarginRight, 4f),
                (StyleKeys.MarginBottom, 4f),
              }}
            />
          );
        }
        @if (selected != "all") {
          return (
            <Label
              text={$"active: {selected}"}
              style={new Style { (StyleKeys.Color, new Color(0.5f, 0.5f, 0.5f)), (StyleKeys.FontSize, 10f) }}
            />
          );
        }
      </VisualElement>
    );
  }

  // в”Ђв”Ђ local function: JSX with @if / @else в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  VirtualNode DeepStatusBadge() {
    return (
      <VisualElement style={new Style { (StyleKeys.MarginBottom, 6f) }}>
        @if (mounted) {
          return (
            <Label
              text={$"mode = {mode}   |   mounted ON"}
              style={new Style { (StyleKeys.Color, new Color(0.4f, 0.9f, 0.6f)), (StyleKeys.FontSize, 11f) }}
            />
          );
        } @else {
          return (
            <Label
              text="mounted OFF"
              style={new Style { (StyleKeys.Color, new Color(0.5f, 0.5f, 0.5f)), (StyleKeys.FontSize, 11f) }}
            />
          );
        }
      </VisualElement>
    );
  }

  // в”Ђв”Ђ setup-code JSX from local function call в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  var deepStatusNode = DeepStatusBadge();

  return (
    <ScrollView style={containerStyle}>
      <Label
        text="Kitchen Sink Component"
        style={new Style { (StyleKeys.FontSize, 16f), ("unityFontStyleAndWeight", FontStyle.Bold), (StyleKeys.MarginBottom, 6f) }}
      />
      @switch (mode) {
        @case "squared":
          return (
            <Label text={$"Mode: Squared Гўв‚¬вЂќ CountГ‚ВІ: {count * count}"} />
          );
        @case "doubled":
          return (
            <Label text={$"Mode: Doubled Гўв‚¬вЂќ ГѓвЂ”2: {doubleCount}"} />
          );
        @case "normal":
          return (
            <VisualElement>
              <Label text={$"Mode: Normal Гўв‚¬вЂќ Count: {count}"} />
              <Button text="-5" onClick={_ => setCount(count - 5)} />
            </VisualElement>
          );
        @default:
          return (
            <Label text={$"Mode: Unknown ({mode})"} />
          );
      }
      @if (count < -5) {
        return (
          <Label text="Count cannot be less than -5!" />
        );
      } @else if (count < 0) {
        return (
          <Label text="Count is negative!" />
        );
      } @else if (count == 0) {
        return (
          <Label text="Count is zero" />
        );
      } @else {
        return (
          <VisualElement>
            @for (int i = 0; i < count; i++) {
              return (
                @if (i % 2 == 0) {
                  return (
                    <Label text={$"Even row {i}"} />
                  );
                } @else {
                  return (
                    <Label text={$"Odd row {i}"} />
                  );
                }
              );
            }
            <Label text={$"Total rows: {count}"} />
          </VisualElement>
        );
      }
      @foreach (var entry in log) {
        return (
          <Label key={entry} text={entry} />
        );
      }
      <VisualElement style={badgeStyle}>
        <Label text={$"Count: {count} Render#: {renderCount}"} />
        <Label text={$"Signal: {signalCount}  Double: {doubleCount}"} />
        <Label text={$"Options: {optionsText}"} style={syncLabelStyle} />
      </VisualElement>
      <VisualElement style={rowStyle}>
        <Button
          text="-5"
          onClick={_ => setCount(count - 5)}
          style={new Style { (StyleKeys.MarginRight, 6f) }}
        />
        <Button
          text="-"
          onClick={_ => setCount(count - 1)}
          style={new Style { (StyleKeys.MarginRight, 6f) }}
        />
        <Label
          text={$"{count}"}
          style={new Style { (StyleKeys.MinWidth, 30f), ("unityTextAlign", "middle-center") }}
        />
        <Button
          text="+"
          onClick={_ => setCount(count + 1)}
          style={new Style { (StyleKeys.MarginRight, 6f) }}
        />
        <Button text="+5" onClick={_ => setCount(count + 5)} />
      </VisualElement>
      <VisualElement style={rowStyle}>
        <Button
          text="Normal"
          onClick={_ => ApplyMode("normal")}
          style={new Style { (StyleKeys.MarginRight, 6f) }}
        />
        <Button
          text="Squared"
          onClick={_ => ApplyMode("squared")}
          style={new Style { (StyleKeys.MarginRight, 6f) }}
        />
        <Button text="Doubled" onClick={_ => ApplyMode("doubled")} />
      </VisualElement>
      <VisualElement style={rowStyle}>
        <Button
          text="ГѓвЂ”3"
          onClick={_ => TripleIncrement()}
          style={new Style { (StyleKeys.MarginRight, 6f) }}
        />
        <Button
          text="Reset"
          onClick={_ => Reset()}
          style={new Style { (StyleKeys.MarginRight, 6f) }}
        />
        <Button text="Shuffle" onClick={_ => ShuffleOptions()} />
      </VisualElement>
      <ToggleButtonGroup value={selected}>
        @foreach (var opt in options) {
          return (
            <Button
              key={opt}
              text={opt}
              onClick={_ => setSelected(options.IndexOf(opt))}
            />
          );
        }
      </ToggleButtonGroup>
      <Label
        text={$"Selected: {(selected < options.Count ? options[selected] : "none")}"}
        style={new Style { (StyleKeys.MarginTop, 4f), (StyleKeys.FontSize, 13f), (StyleKeys.Color, new Color(0.85f, 0.95f, 1f, 1f)) }}
      />
      <Toolbar style={new Style { (StyleKeys.MarginTop, 6f) }}>
        <ToolbarMenu text="Actions" populateMenu={buildMenu} />
      </Toolbar>
      <TabView
        selectedIndex={tabViewProps.SelectedIndex}
        tabs={tabViewProps.Tabs}
        style={tabViewProps.Style}
      />
      <VisualElement
        style={panelStyle}
        extraProps={new Dictionary<string, object> {
          { "onPointerDown", (PointerEventHandler)(e => HandleEvent(e)) },
          { "onPointerMove", (PointerEventHandler)(e => HandleEvent(e)) },
          { "onWheel", (WheelEventHandler)(e => HandleEvent(e)) }
        }}
      >
        <Label
          text="Interact here (pointer and wheel events)"
          style={new Style { (StyleKeys.Color, Color.white) }}
        />
      </VisualElement>
      <Suspense
        isReady={IsLoading}
        fallback={V.Label(new LabelProps { Text = "Suspense fallback..." })}
      >
        <Label text={$"Trigger value: {trigger}"} />
      </Suspense>
      <UitkxTestSubFileDoNotTouch
        message="UitkxCounterFunc Гўв‚¬вЂќ Go-to-definition test"
      />
      <Button
        text={mounted ? "Unmount Portal" : "Mount Portal"}
        onClick={_ => setMounted(!mounted)}
        style={new Style { (StyleKeys.MinWidth, 140f), (StyleKeys.MarginBottom, 6f), (StyleKeys.MarginTop, 4f) }}
      />
      @(portalNode)
      @(inlineNode)
      <UitkxTestSubFileDoNotTouch
        message="UitkxCounterFunc Гўв‚¬вЂќ Go-to-definition test"
      />
      // ГўвЂќв‚¬ГўвЂќв‚¬ visualElementSafe: safe-area-aware wrapper ГўвЂќв‚¬ГўвЂќв‚¬
      <visualElementSafe style={badgeStyle}>
        <Label text="Inside a visualElementSafe (safe-area padding applied)" />
      </visualElementSafe>
      // ГўвЂќв‚¬ГўвЂќв‚¬ Route element with inline JSX (no V.Func / V.Text needed) ГўвЂќв‚¬ГўвЂќв‚¬
      <Router>
        <Route path="/" exact element={<Label text="JSX route Гўв‚¬вЂќ home" />} />
        <Route path="/jsxDemo" element={<Label text="JSX route Гўв‚¬вЂќ demo" />} />
      </Router>
      <UitkxTestSubFileDoNotTouch
        message="UitkxCounterFunc Гўв‚¬вЂќ Go-to-definition test"
      />
      // в”Ђв”Ђ deep nesting: @foreach в†’ @for в†’ @if/@else в†’ @foreach (4 levels) в”Ђв”Ђ
      @(DeepPillBar(deepPills, mode))
      @(deepStatusNode)
      @foreach (var cat in deepCategories) {
        var catColor =
          cat == "A" ? Color.cyan :
          cat == "B" ? Color.yellow :
        new Color(1f, 0.5f, 0.8f);
        var catBadge = (
          <VisualElement
            style={new Style { (StyleKeys.FlexDirection, "row"), (StyleKeys.AlignItems, "center"), (StyleKeys.MarginBottom, 3f) }}
          >
            <Label
              text={$"cat = {cat}"}
              style={new Style { (StyleKeys.Color, catColor), (StyleKeys.FontSize, 12f), (StyleKeys.MarginRight, 6f) }}
            />
            @if (mounted) {
              return (
                <Label
                  text={$"[mode={mode}]"}
                  style={new Style { (StyleKeys.Color, new Color(0.5f, 0.5f, 0.5f)), (StyleKeys.FontSize, 10f) }}
                />
              );
            }
          </VisualElement>
        );

        return (
          <VisualElement
            key={cat}
            style={new Style {
              (StyleKeys.BackgroundColor, new Color(0.1f, 0.1f, 0.15f)),
              (StyleKeys.Padding, 6f),
              (StyleKeys.MarginBottom, 4f),
              (StyleKeys.BorderRadius, 4f),
            }}
          >
            @(catBadge)
            @for (int d = 0; d < count; d++) {
              var depthFrac = count > 1 ? (float)d / (count - 1) : 0f;
              var depthBg = new Color(0.12f + depthFrac * 0.08f, 0.12f, 0.2f - depthFrac * 0.08f);

              return (
                <VisualElement
                  key={$"{cat}-{d}"}
                  style={new Style {
                    (StyleKeys.BackgroundColor, depthBg),
                    (StyleKeys.Padding, 4f),
                    (StyleKeys.MarginBottom, 2f),
                    (StyleKeys.BorderRadius, 3f),
                  }}
                >
                  <Label
                    text={$"  depth = {d}"}
                    style={new Style { (StyleKeys.Color, Color.white), (StyleKeys.FontSize, 11f) }}
                  />
                  @if (d % 2 == 0) {
                    var slotLabel = $"even (cat={cat}, d={d}):";

                    return (
                      <VisualElement
                        style={new Style { (StyleKeys.FlexDirection, "row"), (StyleKeys.FlexWrap, "wrap") }}
                      >
                        <Label
                          text={slotLabel}
                          style={new Style { (StyleKeys.Color, new Color(0.5f, 0.8f, 1f)), (StyleKeys.FontSize, 10f), (StyleKeys.MarginRight, 6f) }}
                        />
                        @foreach (var tag in deepPills) {
                          if (tag == "z" && d == 0) {
                            return null;
                          }
                          var isActive = tag == mode;

                          return (
                            <Label
                              key={tag}
                              text={$"[{tag}]"}
                              style={new Style { (StyleKeys.Color, isActive ? Color.cyan : new Color(0.6f, 0.6f, 0.6f)), (StyleKeys.FontSize, 10f), (StyleKeys.MarginRight, 4f) }}
                            />
                          );
                        }
                      </VisualElement>
                    );
                  } @else {
                    return (
                      <Label
                        text={$" odd depth (d={d})"}
                        style={new Style { (StyleKeys.Color, new Color(0.55f, 0.55f, 0.55f)), (StyleKeys.FontSize, 10f) }}
                      />
                    );
                  }
                </VisualElement>
              );
            }
          </VisualElement>
        );
      }
    </ScrollView>
  );
}
