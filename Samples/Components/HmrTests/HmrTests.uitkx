import { container } from "./SomeOtherName.style"
import isSomethingEven, { getSomething } from "./SomeOtherName.utils"

export VirtualNode HmrTests() {
  var (count, _setCount) = useState(0);

  return (
    <VisualElement style={container}>
      <Text text={$"Count: {count}"} onClick={_ => getSomething()} />
      <Button text="+" onClick={_ => isSomethingEven()} />
    </VisualElement>
  );
}
