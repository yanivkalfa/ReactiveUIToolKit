import { container } from "./SomeStyleFile.style"

export VirtualNode HmrTests() {
  var (count, setCount) = useState(0);

  return (
    <VisualElement style={container}>
      <Text text={$"Cssount: {count}"} />
      <Button text="+" onClick={_ => setCount(count + 1)} />
    </VisualElement>
  );
}
