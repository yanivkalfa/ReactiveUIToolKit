{
  "version": "1.0",
  "description": "UITKX element and directive schema for IDE tooling",
  "universalAttributes": [
    {
      "name": "key",
      "type": "string",
      "description": "Unique reconciler key. Stabilises element identity across re-renders."
    }
  ],
  "directives": [
    {
      "name": "namespace",
      "description": "C# namespace for the generated partial class."
    },
    {
      "name": "component",
      "description": "Name of the component class (must match the .uitkx filename)."
    },
    {
      "name": "using",
      "description": "Adds a using directive to the generated file."
    },
    {
      "name": "props",
      "description": "Declares the props type consumed by this component."
    },
    {
      "name": "key",
      "description": "Sets a static key on the component root element."
    }
  ],
  "controlFlow": [
    {
      "name": "if",
      "description": "Conditional rendering — generates a ternary."
    },
    {
      "name": "else",
      "description": "Else branch of @if."
    },
    {
      "name": "foreach",
      "description": "Loop rendering — generates .Select().ToArray()."
    },
    {
      "name": "switch",
      "description": "Switch expression — generates a C# switch expression."
    },
    {
      "name": "case",
      "description": "Case arm inside @switch."
    },
    {
      "name": "default",
      "description": "Default arm inside @switch."
    },
    {
      "name": "code",
      "description": "Embedded C# code block before the return statement."
    }
  ],
  "elements": {
    "label": {
      "propsType": "LabelProps",
      "description": "Renders a text label (VisualElement wrapping a text element).",
      "acceptsChildren": false,
      "attributes": [
        {
          "name": "text",
          "type": "string",
          "description": "Displayed text content."
        },
        {
          "name": "name",
          "type": "string",
          "description": "VisualElement.name for USS or code queries."
        },
        {
          "name": "className",
          "type": "string",
          "description": "One or more USS class names (space-separated)."
        },
        {
          "name": "style",
          "type": "Style",
          "description": "Inline style overrides."
        },
        {
          "name": "ref",
          "type": "object",
          "description": "Ref to the underlying VisualElement."
        }
      ]
    },
    "button": {
