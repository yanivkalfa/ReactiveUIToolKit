{
  "version": "1.0",
  "description": "UITKX element and directive schema for IDE tooling",
  "universalAttributes": [
    {
      "name": "key",
      "type": "string",
      "description": "Unique reconciler key. Stabilises element identity across re-renders."
    },
    {
      "name": "name",
      "type": "string",
      "description": "VisualElement.name."
    },
    {
      "name": "className",
      "type": "string",
      "description": "USS class names (space-separated)."
    },
    {
      "name": "style",
      "type": "Style",
      "description": "Inline style overrides."
    },
    {
      "name": "ref",
      "type": "object",
      "description": "Ref to the underlying VisualElement."
    },
    {
      "name": "contentContainer",
      "type": "object",
      "description": "Props forwarded to the inner content container."
    },
    {
      "name": "visible",
      "type": "bool",
      "description": "Whether the element is visible."
    },
    {
      "name": "enabled",
      "type": "bool",
      "description": "Whether the element is enabled."
    },
    {
      "name": "tooltip",
      "type": "string",
      "description": "Tooltip text."
    },
    {
      "name": "viewDataKey",
      "type": "string",
      "description": "View data persistence key."
    },
    {
      "name": "pickingMode",
      "type": "PickingMode",
      "description": "Mouse picking mode."
    },
    {
      "name": "focusable",
      "type": "bool",
      "description": "Whether the element can receive focus."
    },
    {
      "name": "tabIndex",
      "type": "int",
      "description": "Tab order index."
    },
    {
      "name": "delegatesFocus",
      "type": "bool",
      "description": "Whether focus is delegated to a child."
    },
    {
      "name": "languageDirection",
      "type": "LanguageDirection",
      "description": "Text language direction."
    },
    {
      "name": "extraProps",
      "type": "Dictionary<string,object>",
      "description": "Arbitrary extra props forwarded to the element."
    },
    {
      "name": "onClick",
      "type": "PointerEventHandler",
      "description": "Pointer click handler."
    },
    {
      "name": "onPointerDown",
      "type": "PointerEventHandler",
      "description": "Pointer down handler."
    },
    {
      "name": "onPointerUp",
      "type": "PointerEventHandler",
      "description": "Pointer up handler."
    },
    {
      "name": "onPointerMove",
      "type": "PointerEventHandler",
      "description": "Pointer move handler."
    },
    {
      "name": "onPointerEnter",
      "type": "PointerEventHandler",
      "description": "Pointer enter handler."
    },
    {
      "name": "onPointerLeave",
      "type": "PointerEventHandler",
      "description": "Pointer leave handler."
    },
    {
      "name": "onWheel",
      "type": "WheelEventHandler",
      "description": "Mouse wheel handler."
    },
    {
      "name": "onScroll",
      "type": "WheelEventHandler",
      "description": "Scroll handler."
    },
    {
      "name": "onDragEnter",
      "type": "DragEventHandler",
      "description": "Drag enter handler."
    },
    {
      "name": "onDragLeave",
      "type": "DragEventHandler",
      "description": "Drag leave handler."
    },
    {
      "name": "onDragUpdated",
      "type": "DragEventHandler",
      "description": "Drag updated handler."
    },
    {
      "name": "onDragPerform",
      "type": "DragEventHandler",
      "description": "Drag perform handler."
    },
    {
      "name": "onDragExited",
      "type": "DragEventHandler",
      "description": "Drag exited handler."
    },
    {
      "name": "onFocus",
      "type": "FocusEventHandler",
      "description": "Focus gained handler."
    },
    {
      "name": "onBlur",
      "type": "FocusEventHandler",
      "description": "Focus lost handler."
    },
    {
      "name": "onFocusIn",
      "type": "FocusEventHandler",
      "description": "Focus-in (bubbling) handler."
    },
    {
      "name": "onFocusOut",
      "type": "FocusEventHandler",
      "description": "Focus-out (bubbling) handler."
    },
    {
      "name": "onKeyDown",
      "type": "KeyboardEventHandler",
      "description": "Key down handler."
    },
    {
      "name": "onKeyUp",
      "type": "KeyboardEventHandler",
      "description": "Key up handler."
    },
    {
      "name": "onInput",
      "type": "InputEventHandler",
      "description": "Input event handler."
    },
    {
      "name": "onGeometryChanged",
      "type": "GeometryChangedEventHandler",
      "description": "Geometry changed handler."
    },
    {
      "name": "onAttachToPanel",
      "type": "PanelLifecycleEventHandler",
      "description": "Attach to panel handler."
    },
    {
      "name": "onDetachFromPanel",
      "type": "PanelLifecycleEventHandler",
      "description": "Detach from panel handler."
    }
  ],
  "directives": [
    {
      "name": "namespace",
      "description": "C# namespace for the generated partial class."
    },
    {
      "name": "component",
      "description": "Name of the component class (must match the .uitkx filename)."
    },
    {
      "name": "using",
      "description": "Adds a using directive to the generated file."
    },
    {
      "name": "props",
      "description": "Declares the props type consumed by this component."
    },
    {
      "name": "key",
      "description": "Sets a static key on the component root element."
    },
    {
      "name": "code",
      "description": "Embedded C# code block before the return statement."
    }
  ],
  "controlFlow": [
    {
      "name": "if",
      "description": "Conditional rendering — generates a ternary."
    },
    {
      "name": "else",
      "description": "Else branch of @if."
    },
    {
      "name": "foreach",
      "description": "Loop rendering — generates .Select().ToArray()."
    },
    {
      "name": "switch",
      "description": "Switch expression — generates a C# switch expression."
    },
    {
      "name": "case",
      "description": "Case arm inside @switch."
    },
    {
      "name": "default",
      "description": "Default arm inside @switch."
    },
    {
      "name": "code",
      "description": "Embedded C# code block before the return statement."
    },
    {
      "name": "for",
      "description": "C-style for loop — generates a standard for loop."
    },
    {
      "name": "while",
      "description": "While loop — generates a while loop."
    },
    {
      "name": "break",
      "description": "Loop-flow statement valid inside @for/@while bodies."
    },
    {
      "name": "continue",
      "description": "Loop-flow statement valid inside @for/@while bodies."
    }
  ],
