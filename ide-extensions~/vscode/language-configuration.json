{
  "comments": {
    "blockComment": [
      "<!--",
      "-->"
    ]
  },
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "(",
      ")"
    ],
    [
      "<",
      ">"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string"
      ]
    },
    {
      "open": "<!--",
      "close": "-->"
    }
  ],
  "surroundingPairs": [
    [
      "{",
      "}"
    ],
    [
      "(",
      ")"
    ],
    [
      "\"",
      "\""
    ],
    [
      "<",
      ">"
    ]
  ],
  "wordPattern": "[A-Za-z][A-Za-z0-9_-]*",
  "indentationRules": {
    "increaseIndentPattern": "<([A-Za-z][^/>]*)(?<!/)>\\s*$",
    "decreaseIndentPattern": "^\\s*</"
  },
  "folding": {
    "markers": {
      "start": "^\\s*<!--\\s*#region\\b",
      "end": "^\\s*<!--\\s*#endregion\\b"
    }
  }
}